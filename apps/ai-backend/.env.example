# PiAPI key (Trellis 3D generation) — get at piapi.ai
TELLIST_AI=

# HuggingFace token — get at huggingface.co/settings/tokens
# Note: token must have "Inference Provider" billing permission for concept studio
HF_KEY=

# Tripo3D key — get at tripo3d.ai
TRIPO_KEY=

# Groq key (primary LLM for chat) — free at console.groq.com
GROQ_KEY=

# Gemini key (fallback LLM, used only if GROQ_KEY not set) — free at aistudio.google.com
GEMINI_KEY=

# HuggingFace model for concept studio image generation
# If HF_KEY lacks "Inference Providers" permission, images fall back to the
# free Pollinations API (slower, rate-limited). Fix the token for fast parallel gen.
CONCEPT_MODEL=black-forest-labs/FLUX.1-schnell

# Extra CORS origins (comma-separated) — add your frontend URL if not localhost:3000/3001/3002/8080
# CORS_ORIGINS=https://your-deployed-frontend.com
